{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "sourceMap": true,
    "declaration": true,
    "composite": true,
    "strict": true,
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noPropertyAccessFromIndexSignature": true,

    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      // Paths are relative to packages/ directory (where baseUrl is set)
      "@tao-compiler": ["./compiler/tao-compiler.ts"],
      "@tao-compiler/*": ["./compiler/compiler-src/*"],
      "@tao-formatter/*": ["./compiler/formatter-src/*"],
      "@shared/*": ["./shared/shared-src/*"],
      "@tao-cli/*": ["./tao-cli/cli-src/*"]
    }
  },
  "include": [
    "**/src/**/*",
    "**/test/**/*",
    "./shared/shared-src/**/*"
  ],
  "exclude": [
    "**/node_modules/**/*"
  ]
}

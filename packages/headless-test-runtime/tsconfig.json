{
  "extends": "../tsconfig.base.json",
  "references": [
    { "path": "../compiler" },
    { "path": "../tao-cli" }
  ],
  "include": [
    "src/**/*",
    "tests/**/*"
  ],
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "incremental": false,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node", "jest", "react"]
  },
  "exclude": [
    "**/node_modules/**/*",
    "src/_gen-runtime-tests/**/*",
    "src/_gen-tao-compiler/test-*-app-output.tsx"
  ]
}

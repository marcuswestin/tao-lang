{
  "extends": "../tsconfig.base.json",
  "references": [
    {
      "path": "../compiler"
    },
    {
      "path": "../tao-cli"
    }
  ],
  "include": [
    "scripts/**/*.ts",
    "src/**/*",
    "tests/**/*"
  ],
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "incremental": false,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": [
      "node",
      "jest",
      "react"
    ]
  },
  "exclude": [
    "**/node_modules/**/*"
  ]
}

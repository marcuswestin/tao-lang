{
  "name": "@shared",
  "extends": "../tsconfig.dev.json",
  "main": "shared.ts",
  "references": [
    {
      "path": "../compiler"
    }
  ],
  "include": [
    "shared-src/**/*",
    "shared-tests/**/*",
    "scripts/**/*"
  ],
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "incremental": false,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true
  }
}

{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "..",
    "composite": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true
  },
  "include": [
    "formatter.ts",
    "formatter-src/**/*",
    "formatter-tests/**/*",
    "../parser/src/parser.ts",
    "../parser/src/**/*",
    "../shared/shared-src/**/*",
    "../compiler/tao-compiler.ts",
    "../compiler/compiler-src/**/*"
  ]
}

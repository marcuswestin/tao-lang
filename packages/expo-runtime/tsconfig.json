{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@shared/*": [
        "../shared/shared-src/*"
      ],
      "@shared": [
        "../shared/shared-src/shared.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "_gen/_gen-runtime-tests/**/*"
  ]
}

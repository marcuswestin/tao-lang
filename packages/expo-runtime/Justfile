import "../shared/just/all-imports.just"

release-prep: _deps prebuild test

prebuild: build install-ios-platform
    bunx expo prebuild

build: _deps
    # Hermes (expo runner) requires import.meta.url to be defined.
    # It's a hack, and I'd like to make it cleaner.
    just cli build-lib {{ justfile_directory() }}/_gen-tao-lib

watch-lib: _deps
    just cli watch-lib {{ justfile_directory() }}/_gen-tao-lib

install-ios-platform:
    if command -v xcodebuild >/dev/null; then xcodebuild -downloadPlatform iOS; else echo "xcodebuild not found; skipping iOS platform install"; fi

run: _deps
    BROWSER="none" bunx expo start --web --ios --android

web: _deps
    BROWSER="none" bunx expo start --web

ios: _deps
    BROWSER="none" bunx expo start --ios

device: _deps install-ios-platform
    BROWSER="none" bunx expo run:ios --device

android: _deps
    BROWSER="none" bunx expo start --android

clean:
    rm -rf .expo
    rm -f expo-env.d.ts
    find . -maxdepth 1 -name '.metro-health-check*' -delete

clean-full: clean
    rm -rf ./node_modules ./ios ./android
    rm -rf ~/.expo
    watchman watch-del {{ justfile_directory() }}/../.. && watchman watch-project '{{ justfile_directory() }}'/../..

JEST_ARGS := "--detectOpenHandles --watchman=false"
JEST_WATCH_ARGS := JEST_ARGS + " --watch --silent --reporter=dot"

[no-quiet]
test *FILTER: _deps build
    bunx jest {{ JEST_ARGS }} -t {{ FILTER }}

watch *FILTER:
    bunx jest {{ JEST_WATCH_ARGS }} -t {{ FILTER }}

_deps: _bun_deps

lint:
    bunx expo lint
    bunx eslint

import "../shared/just/all-imports.just"

dev:
    cursor --extensionDevelopmentPath .

run:
    echo
    echo "\tBuild and package extension..."
    just package
    echo "\tInstall extension..."
    just uninstall-extension > /dev/null 2>&1 || true
    just install-extension > /dev/null
    echo "\tCheck extension installation..."
    set -e && cursor --list-extensions | grep "tao.tao-ide-extension" || { echo "Installation failed -- extension not found" >&2; exit 1; }
    echo "\n\t* Extension installed - restart IDE *\n"
    # just restart-cursor
    echo "\tCheck for type errors..."
    # just check

build: build-package-and-install

# Build and package. Skip if `TAO_SKIP_COMPILER_BUILD=1`
build-package-and-install: _deps
    just _skip_if_env_eq TAO_SKIP_COMPILER_BUILD 1 || just compiler build
    just package
    just install-extension

# Package the extension. This calls `just _npm_package_script_vscode_prepublish` via package.json script `vscode:prepublish`.
package: _deps
    bunx @vscode/vsce package --allow-missing-repository --out ../../.builds 1> /dev/null

_npm_package_script_vscode_prepublish:
    node esbuild.config.ts

uninstall-extension:
    cursor --uninstall-extension tao.tao-ide-extension
    code --uninstall-extension tao.tao-ide-extension

install-extension:
    cursor --install-extension ../../.builds/tao-ide-extension-0.0.1.vsix --force
    code --install-extension ../../.builds/tao-ide-extension-0.0.1.vsix --force

restart-cursor:
    osascript -e 'quit app "Cursor"'
    sleep 0.25 && open -a Cursor && sleep 0.5 && open -a Cursor && sleep 0.5 && open -a Cursor

check:
    tsc -b tsconfig.json

_deps: _bun_deps

{
  "extends": "./tsconfig.shared.json",
  "compilerOptions": {
    "module": "ESNext",
    "composite": true,
    "noUnusedLocals": true,
    "rootDir": "..",
    "emitDeclarationOnly": true,
    "outDir": "../../.builds/ts-packages/@tao-compiler"
  },
  "include": [
    "tao-compiler.ts",
    "compiler-src/**/*",
    "compiler-tests/**/*",
    "../shared/shared-src/**/*",
    "../parser/src/parser.ts",
    "../parser/src/**/*",
    "../formatter/formatter.ts",
    "../formatter/src/**/*"
  ]
}

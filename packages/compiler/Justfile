import "../shared/just/all-imports.just"

test *PATTERNS: _deps
    bun test --reporter=dot --test-name-pattern "{{ PATTERNS }}"

watch-test *PATTERNS: _deps
    bun test . --watch --no-clear-screen --reporter=dot --test-name-pattern "{{ PATTERNS }}"

build: _deps
    # `-b --force`: composite incremental can leave orphan `.tsbuildinfo` without `.d.ts` (TS6305 in ide-extension); force a consistent emit.
    bunx tsc -b tsconfig.json --force


watch-compiler: _deps
    bun -e "import 'compiler-src/compiler-main'; console.log('Reload...'); " --watch --no-clear-screen

_deps: _bun_deps
    just gen

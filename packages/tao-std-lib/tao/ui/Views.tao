inject raw ```ts
type RenderTextViewParams = {
    value?: string
    RNStyle?: RN.TextStyle
  }

  type RenderViewParams = {
    children?: ReactNode
    RNProps?: Record<string, unknown>
    RNStyle?: RN.ViewStyle
    styles?: RN.ViewStyle
  }

  export const ALRuntime = {
    ui: {
      renderTextView(renderViewParams: RenderTextViewParams) {
        return <RN.Text style={renderViewParams.RNStyle}>{renderViewParams.value}</RN.Text>
      },
      renderView(
        _viewName: string,
        Component: ComponentType<any>,
        renderViewParams: RenderViewParams,
      ) {
        return (
          <Component
            {...renderViewParams.RNProps}
            style={renderViewParams.RNStyle ?? renderViewParams.styles}
          >
            {renderViewParams.children}
          </Component>
        )
      },
    },
  }
```

share view Box {
  inject ```ts
    const renderViewParams = { children: props.children, params: {}, styles: {}, layouts: {}, uiLabel: '', RNProps: {}, RNStyle:{} }
    renderViewParams.styles = { backgroundColor: 'red', padding: 10 }
    return ALRuntime.ui.renderView('Box', RN.View, renderViewParams)
  ```
}

share view Col {
  inject ```ts
    const renderViewParams = { children: props.children, params: {}, styles: {}, layouts: {}, uiLabel: '', RNProps: {}, RNStyle:{} }
    renderViewParams.styles = { flexDirection: 'column', backgroundColor: 'blue', padding: 10 }
    return ALRuntime.ui.renderView('Col', RN.View, renderViewParams)
  ```
}


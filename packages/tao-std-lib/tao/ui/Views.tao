  inject ```ts
    const renderViewParams = { children: props.children, params: {}, styles: {}, layouts: {}, uiLabel: '', RNProps: {}, RNStyle:{} }
    renderViewParams.styles = { flexDirection: 'row', backgroundColor: 'yellow' }

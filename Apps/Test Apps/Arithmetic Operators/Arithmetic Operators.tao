use Text, Row, Button from @tao/ui

app ArithmeticOperatorsApp {
    ui RootView
}

state GlobalCount = 0

alias Name = "Ro"

view RootView {
    state LocalCount = 100
    alias Greeting = "Hello"
    Row {
        Text value Greeting
        Text value Name
    }
    alias DoubleGlobal = GlobalCount * 2
    Row {
        alias DoubleLocal = LocalCount * 2
        Button title "Increment", Action action {
            set GlobalCount = GlobalCount + 1
            set LocalCount = LocalCount * 10
        }
        Text value "GlobalCount: "
        Text value GlobalCount
        Text value "DoubleGlobal: "
        Text value DoubleGlobal
        Text value "LocalCount: "
        Text value LocalCount
        Text value "DoubleLocal: "
        Text value DoubleLocal
    }
}

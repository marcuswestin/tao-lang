use Text, Number, Row, Button from @tao/ui

app ArithmeticOperatorsApp {
   ui RootView
}

state GlobalCount = 0

alias Name = "Ro"

view RootView {
   state LocalCount = 100
   alias Greeting = "Hello"
   Row {
      Text Greeting
      Text Name
   }
   alias DoubleGlobal = GlobalCount * 2
   Row {
      alias DoubleLocal = LocalCount * 2
      Button "Increment", action {
         set GlobalCount = GlobalCount + 1
         set LocalCount = LocalCount * 10
      }
      Text "GlobalCount: "
      Number GlobalCount
      Text "DoubleGlobal: "
      Number DoubleGlobal
      Text "LocalCount: "
      Number LocalCount
      Text "DoubleLocal: "
      Number DoubleLocal
   }
}

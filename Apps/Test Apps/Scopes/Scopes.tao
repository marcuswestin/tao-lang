use Text, Button, Row, Col from @tao/ui

app ScopesApp {
   ui RootView
}

state FileState = 100

action FileAction {
   set FileState += 1
}

view RootView {
   state ViewState = 200
   Button "${ FileState }", FileAction { }
   Button "${ ViewState }", ViewAction { }
   action ViewAction {
      set ViewState += 1
   }
   Row {
      state InnerState = 300
      Button "${ InnerState }", InnerAction { }
      action InnerAction {
         set InnerState += 1
         set FileState += 1
      }
      Col {
         state DeepState = 400
         Button "${ DeepState }", DeepAction { }
         action DeepAction {
            set DeepState += 1
            set InnerState += 1
            set FileState += 1
         }
      }
   }
}

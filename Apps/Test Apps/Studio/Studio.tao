use Text, Button from @tao/ui

app TaoStudio {
   ui RootView
}

state GlobalCount = 100

view RootView {
   Text "Hello World"
   CountView { }
   Text "Global Count: " { }
   Button "${ GlobalCount }", GlobalIncrementAction { }
}

view CountView {
   state LocalCount = 200
   Text "Local Count:" { }
   Button "${ LocalCount }", LocalIncrementAction { }
   action LocalIncrementAction {
      set LocalCount += 1
      set GlobalCount += 1
   }
   state SubCount = 300
   action SubIncrementAction {
      set SubCount += 1
      set LocalCount += 1
      set GlobalCount += 1
   }
   view SubCountView {
      Text "Sub Count 1:" { }
      Button "${ SubCount }", SubIncrementAction { }
   }
   SubCountView { }
}

action GlobalIncrementAction {
   set GlobalCount += 1
}

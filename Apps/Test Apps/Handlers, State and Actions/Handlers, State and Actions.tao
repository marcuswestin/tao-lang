use Text, Number, Button, Row from @tao/ui

app HandlersStateAndActionsApp {
   ui RootView
}

state GlobalCount = 300

view RootView {
   state Count1 = 100
   Number GlobalCount
   Row {
      state Count2 = 200
      Button "${ Count1 }", IncrementAction { }
      Button "${ Count2 }", IncrementAction2 { }
      action IncrementAction2 {
         set GlobalCount += 1
         set Count2 += 1
      }
   }
   action IncrementAction {
      set GlobalCount += 1
      set Count1 += 1
   }
}

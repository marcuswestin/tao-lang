use KnifeBlock, RootView from ./counter
use FridgeView
use Col, Row, Text, Box from tao/ui

app KitchenSink {
    ui AppView
}

view AppView {
    Text value "Hello Kitchen Sink" { }
    RootView { }
    HandlerTestView { }
}

view HandlerTestView {
    TestButton Action TestAction { }
}

view TestButton Action string {
    Box {
        inject raw ```ts <RN.Pressable onPress={props.Action}> ```
        Box {
            Text value "Test Button" { }
        }
        inject raw ```ts </RN.Pressable> ```
    }
}

action TestAction message string {
    inject ```ts
        alert("Test Action")
    ```
}
